OPENAI_API_KEY=
OPENAI_API_BASE=
OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
TAVILY_API_KEY=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=
LANGSMITH_TRACING=

# Only necessary for Open Agent Platform
SUPABASE_KEY=
SUPABASE_URL=
# Should be set to true for a production deployment on Open Agent Platform. Should be set to false otherwise, such as for local development.
GET_API_KEYS_FROM_CONFIG=false

# OpenCode Go example
# 1. Put your OpenCode Go API key in OPENAI_API_KEY.
# 2. Point the OpenAI-compatible client at the OpenCode Go base URL.
# 3. Use OpenCode Go model IDs with the "openai:" LangChain prefix.
#
# OPENAI_API_KEY=your_opencode_go_api_key
# OPENAI_API_BASE=https://opencode.ai/zen/go/v1
# OPENAI_BASE_URL=https://opencode.ai/zen/go/v1
# SUMMARIZATION_MODEL=openai:deepseek-v4-flash
# RESEARCH_MODEL=openai:kimi-k2.6
# COMPRESSION_MODEL=openai:kimi-k2.6
# FINAL_REPORT_MODEL=openai:kimi-k2.6
